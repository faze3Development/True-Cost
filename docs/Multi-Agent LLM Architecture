import pandas as pd
import numpy as np
import statsmodels.api as sm

class HedonicDealScorer:
    """
    Executes a Hedonic Pricing Model utilizing Ordinary Least Squares (OLS) 
    to determine the intrinsic market value of a property and isolate 
    mispriced assets via residual analysis.
    """
    def __init__(self, market_data_df: pd.DataFrame):
        """
        market_data_df: A pandas DataFrame containing recent historical apartment listings.
        Must include columns: 'Rent', 'SqFt', 'Bedrooms', 'Distance_to_CBD', 'Crime_Index'.
        """
        self.market_data = market_data_df
        self.model = None
        
    def train_hedonic_model(self):
        """
        Trains the econometric OLS regression model on local market comparables 
        to calculate the implicit shadow prices (beta coefficients) of attributes.
        """
        # Define independent variables (X) matrix
        X = self.market_data]
        
        # Define dependent variable (y). Log-linear transformation is standard 
        # in housing economics to account for exponential price scaling.
        y = np.log(self.market_data) 
        
        # Add a constant (beta_0 intercept) to the independent variables matrix
        X = sm.add_constant(X)
        
        # Fit the Ordinary Least Squares model
        self.model = sm.OLS(y, X).fit()
        # The summary outputs R-squared, P-values, and Beta Coefficients
        print(self.model.summary()) 
        
    def score_apartment(self, target_unit_features: list, actual_asking_rent: float) -> dict:
        """
        Calculates the exact residual (Deal Score) for a specific target apartment.
        A highly negative residual mathematically implies the apartment is underpriced.
        """
        if self.model is None:
            raise ValueError("Model must be trained before scoring.")
            
        # Format features identically to the trained X matrix columns (including constant)
        features_with_constant = [1.0] + target_unit_features 
        
        # Predict the log(Rent) and convert back to nominal dollar values
        predicted_log_rent = self.model.predict(features_with_constant)
        predicted_rent = np.exp(predicted_log_rent)
        
        # Calculate the Residual (Actual - Predicted)
        residual = actual_asking_rent - predicted_rent
        
        # Calculate Deal Score as a percentage of mispricing
        percent_mispriced = (residual / predicted_rent) * 100
        
        return {
            "Predicted_Intrinsic_Rent": predicted_rent,
            "Actual_Asking_Rent": actual_asking_rent,
            "Residual_Delta": residual,
            "Deal_Score_Percent": percent_mispriced
        }

