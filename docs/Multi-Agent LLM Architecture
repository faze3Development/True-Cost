Python Implementation: Operating Expense Normalization
This function ensures that a baseline utility and insurance cost is universally applied to any residential unit that does not explicitly include them in the gross rent, preventing artificially deflated price comparisons.
class OperatingCostEvaluator:
    """
    Normalizes operational overhead by applying statistical averages 
    for utilities and risk mitigation based on unit size and lease structure.
    """
    def __init__(self, bedrooms: int, square_footage: float, 
                 utilities_included: bool = False, internet_included: bool = False):
        self.bedrooms = bedrooms
        self.square_footage = square_footage
        self.utilities_included = utilities_included
        self.internet_included = internet_included
        
        # 2025 National Baseline Averages
        self.avg_renters_insurance = 15.00 # Based on $170 annual HO-4 policy
        self.avg_internet = 71.90          # Standard broadband package
        
    def estimate_monthly_utilities(self) -> float:
        """
        Estimates utility costs using a hybrid approach of bedroom count 
        and square footage multipliers if exact bills are unknown.
        """
        if self.utilities_included:
            return 0.0
            
        # Scaling utility proxy by bedroom count based on 2025 Apartment List data
        if self.bedrooms <= 1:
            base_estimate = 144.00
        elif self.bedrooms == 2:
            base_estimate = 211.00
        else:
            base_estimate = 211.00 + (self.bedrooms - 2) * 60.00
            
        # Cross-reference with square footage multiplier ($1.50 - $2.70 range)
        sqft_estimate = self.square_footage * 2.00 / 12 # Monthly approximation
        
        # Return the blended average to smooth anomalies
        return (base_estimate + sqft_estimate) / 2
            
    def calculate_total_operating_overhead(self) -> float:
        """Aggregates the total hidden monthly operating burden."""
        utility_cost = self.estimate_monthly_utilities()
        internet_cost = 0.0 if self.internet_included else self.avg_internet
        
        return utility_cost + internet_cost + self.avg_renters_insurance

